# Backend configuration (§8). Copy to .env and adjust.
DATABASE_URL=mysql+asyncmy://netxaura:netxaura@localhost:3306/netxaura
CORS_ORIGINS=http://localhost:5173
TRANSFER_TTL_SECONDS=10
GESTURE_COOLDOWN_MS=800
CONFIDENCE_THRESHOLD=0.7
WORKSPACE_TTL_HOURS=2

# Housekeeping + WS hardening (defaults shown)
CLEANUP_INTERVAL_SECONDS=900
WS_MAX_MESSAGE_BYTES=262144
WS_TELEMETRY_RATE_PER_SEC=40
WS_TELEMETRY_BURST=60
WS_CONTROL_RATE_PER_SEC=5
WS_CONTROL_BURST=10
